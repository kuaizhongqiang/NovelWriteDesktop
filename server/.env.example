# ============ NovelWrite Server 配置 ============
# 复制此文件为 .env 并填入实际值

# 服务端口
PORT=3002

# HTTPS 配置（生产环境建议启用）
# 使用反向代理（如 Nginx/Caddy）终止 TLS

# DeepSeek API 配置（AI 功能必需）
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_ENDPOINT=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-v4-flash

# 数据库路径（默认 ./novelwrite.db）
NOVELWRITE_DB_PATH=./novelwrite.db

# Cookie 签名密钥（生产环境建议修改）
SESSION_SECRET=novelwrite-default-secret

# Debug 模式（设为 1 开启 CORS/请求日志）
DEBUG=0
